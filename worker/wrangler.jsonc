{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "ai-prompting-analytics-proxy",
  "main": "index.js",
  "compatibility_date": "2026-05-01",
  // Custom domain is bound here so `wrangler deploy` provisions the DNS
  // record automatically. The existing `analytics CNAME cloud.umami.is`
  // (DNS-only) MUST be deleted from the zone before the first deploy,
  // otherwise wrangler refuses to create the route.
  "routes": [
    {
      "pattern": "analytics.ai-prompting.sh/*",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
