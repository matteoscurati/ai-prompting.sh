# Analytics (optional — leave both empty to disable).
#
# Provider: Umami Cloud (https://cloud.umami.is), EU region (Frankfurt).
# Privacy: no cookies, no fingerprinting, IP hashed with a daily-rotating
# salt and discarded. See /privacy on the site for the full policy.
#
# The script URL points to a first-party subdomain proxied by a small
# Cloudflare Worker (see worker/README.md). This is what bypasses
# ad-blockers — pointing directly at cloud.umami.is would be blocked
# by uBlock and Brave Shields by default.
#
# Both vars are PUBLIC_-prefixed because Astro requires that for values
# rendered to the client; the website ID is not a secret.
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SCRIPT_URL=https://analytics.ai-prompting.sh/script.js
