# Cloudflare Pages cache rules.
# Source of truth for HTTP headers served from the edge.

# Long-lived hashed assets (Astro emits content-hashed filenames in /_astro/).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# OG image and favicon — medium cache, edits are infrequent but possible.
/og-image.png
  Cache-Control: public, max-age=86400, must-revalidate
/og-image.svg
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=604800, must-revalidate

# Sitemap and robots — short cache so updates propagate quickly.
/sitemap-index.xml
  Cache-Control: public, max-age=3600, must-revalidate
/sitemap-0.xml
  Cache-Control: public, max-age=3600, must-revalidate
/robots.txt
  Cache-Control: public, max-age=3600, must-revalidate

# Prose CSS — content-addressed via filename, cache 1 day.
/prose.css
  Cache-Control: public, max-age=86400, must-revalidate

# All other content (HTML, by exclusion) — short cache so copy edits go live fast.
/*
  Cache-Control: public, max-age=300, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
