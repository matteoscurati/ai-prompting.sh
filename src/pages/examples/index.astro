---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import { EXAMPLES } from '../../data/examples';
---

<BaseLayout
  title="aiprompting examples — prompt before/after with scores"
  description="Real before/after prompt improvements with 0–100 scores: vague writing, under-specified coding tasks, ambiguous research scope, and tool-using agent prompts."
  path="/examples"
>
  <header class="mb-12">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">Examples</h1>
    <p class="mt-3 text-[var(--color-muted)] max-w-2xl">
      Real input → real output, generated by the deterministic CLI. Scores are heuristic estimates
      from the 100-point rubric. The Skill version (semantic rewrite by the host agent) typically
      produces stronger context and constraint sections.
    </p>
  </header>

  <div class="space-y-12">
    {EXAMPLES.map((ex) => (
      <BeforeAfter
        before={ex.before}
        after={ex.after}
        scoreBefore={ex.scoreBefore}
        scoreAfter={ex.scoreAfter}
        label={ex.label}
      />
    ))}
  </div>

  <section class="mt-16 pt-12 border-t border-[var(--color-border)]">
    <h2 class="text-xl font-semibold mb-3">Got your own?</h2>
    <p class="text-[var(--color-muted)] mb-2">
      Open a PR adding your example to
      <a href="https://github.com/matteoscurati/aiprompting/tree/main/aiprompting/examples" class="text-[var(--color-fg)] underline decoration-[var(--color-border)] hover:decoration-[var(--color-accent)]">
        aiprompting/examples/
      </a>. Each example becomes a regression test for the CLI.
    </p>
  </section>
</BaseLayout>
