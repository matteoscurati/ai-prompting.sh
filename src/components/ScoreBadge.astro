---
type Tone = 'good' | 'mid' | 'low';

interface Props {
  score: number;
  delta?: number;
  label?: string;
}
const { score, delta, label } = Astro.props;

const tone: Tone = score >= 80 ? 'good' : score >= 50 ? 'mid' : 'low';
const toneClass: Record<Tone, string> = {
  good: 'border-[var(--color-tone-good)]/50 text-[var(--color-tone-good)]',
  mid: 'border-[var(--color-tone-mid)]/50 text-[var(--color-tone-mid)]',
  low: 'border-[var(--color-tone-low)]/50 text-[var(--color-tone-low)]'
};
---

<span
  class={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded font-mono text-xs border ${toneClass[tone]}`}
>
  {label && <span class="opacity-60">{label}</span>}
  <span>{score}/100</span>
  {delta !== undefined && delta > 0 && <span class="opacity-80">+{delta}</span>}
</span>
