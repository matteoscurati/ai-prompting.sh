---
import ScoreBadge from './ScoreBadge.astro';

interface Props {
  before: string;
  after: string;
  scoreBefore: number;
  scoreAfter: number;
  label?: string;
}
const { before, after, scoreBefore, scoreAfter, label } = Astro.props;

const delta = scoreAfter - scoreBefore;
const panels = [
  { kind: 'before', heading: 'Before', text: before, score: scoreBefore, delta: undefined as number | undefined },
  { kind: 'after', heading: 'After', text: after, score: scoreAfter, delta }
] as const;
---

<div class="space-y-3">
  {label && <h3 class="text-sm uppercase tracking-wide text-[var(--color-muted)]">{label}</h3>}
  <div
    class="grid md:grid-cols-2 gap-px bg-[var(--color-border)] rounded-lg overflow-hidden border border-[var(--color-border)]"
  >
    {panels.map((panel) => (
      <div class="bg-[var(--color-subtle)] p-4">
        <div class="flex items-center justify-between mb-3">
          <span
            class={`text-xs uppercase tracking-wide ${panel.kind === 'after' ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]'}`}
          >
            {panel.heading}
          </span>
          <ScoreBadge score={panel.score} delta={panel.delta} />
        </div>
        <pre
          class={`text-xs sm:text-sm whitespace-pre-wrap font-mono leading-relaxed ${panel.kind === 'after' ? 'text-[var(--color-fg)]' : 'text-[var(--color-muted)]'}`}
        >{panel.text}</pre>
      </div>
    ))}
  </div>
</div>
