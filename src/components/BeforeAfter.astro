---
import ScoreBadge from './ScoreBadge.astro';

interface Props {
  before: string;
  after: string;
  scoreBefore: number;
  scoreAfter: number;
  label?: string;
}
const { before, after, scoreBefore, scoreAfter, label } = Astro.props;
---

<div class="space-y-3">
  {label && <h3 class="text-sm uppercase tracking-wide text-[var(--color-muted)]">{label}</h3>}
  <div
    class="grid md:grid-cols-2 gap-px bg-[var(--color-border)] rounded-lg overflow-hidden border border-[var(--color-border)]"
  >
    <div class="bg-[var(--color-subtle)] p-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs uppercase tracking-wide text-[var(--color-muted)]">Before</span>
        <ScoreBadge score={scoreBefore} />
      </div>
      <pre
        class="text-xs sm:text-sm whitespace-pre-wrap font-mono text-[var(--color-muted)] leading-relaxed"
      >{before}</pre>
    </div>
    <div class="bg-[var(--color-subtle)] p-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs uppercase tracking-wide text-[var(--color-accent)]">After</span>
        <ScoreBadge score={scoreAfter} delta={scoreAfter - scoreBefore} />
      </div>
      <pre
        class="text-xs sm:text-sm whitespace-pre-wrap font-mono text-[var(--color-fg)] leading-relaxed"
      >{after}</pre>
    </div>
  </div>
</div>
